From 8fa73d76c4034e005372132f5671536a010dee94 Mon Sep 17 00:00:00 2001
From: Mahesh Vaidya <mahesh.vaidya@altera.com>
Date: Fri, 29 Aug 2025 03:07:53 -0700
Subject: [PATCH] Reserve RAM area required by pcie rootport on FPGA

Reserve 0x1000 size space in system memory at 0x7EA00000, required
by the rootport design to handle MSI dummy write requests sent by
MSI ordering module.

Upstream-Status: Pending
Signed-off-by: Mahesh Vaidya <mahesh.vaidya@altera.com>
---
 arch/arm64/boot/dts/intel/socfpga_agilex.dtsi | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/arch/arm64/boot/dts/intel/socfpga_agilex.dtsi b/arch/arm64/boot/dts/intel/socfpga_agilex.dtsi
index afe7759086cb..d88db7d707d9 100644
--- a/arch/arm64/boot/dts/intel/socfpga_agilex.dtsi
+++ b/arch/arm64/boot/dts/intel/socfpga_agilex.dtsi
@@ -25,6 +25,12 @@ service_reserved: svcbuffer@0 {
 			alignment = <0x1000>;
 			no-map;
 		};
+
+		fpga_rootport_reserved: fpga_rootport_reserved@7EA00000 {
+			reg = <0x0 0x7EA00000 0x0 0x1000>;
+			alignment = <0x1000>;
+			no-map;
+                };
 	};
 
 	cpus {
-- 
2.34.1

